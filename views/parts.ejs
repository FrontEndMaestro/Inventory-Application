<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Parts</title>
  </head>
  <body>
    <% parts.forEach(part=>{ %>
        <ul>Part Name:<%= part.part_name %>
        Model Name: <%= part.car_name %>
        Price: <%= part.price %>
        <a href="parts/update/<%=part.id%>">Edit</a>
        <button onclick="deletePart('<%=part.id%>')">Delete</button>
        </ul>
<%})%>
  </body>
  <script>
   async function deletePart(partId){
      try {
        const response=await fetch(`/parts/delete/${partId}`,{
        method:"DELETE"})
        if(response.ok){
          window.location.reload()
        }
        else{
          console.error("failed to delete",response.status)
        }
      
      } catch (error) {
        console.error("error deleting item",error)
      }
      
    }
  </script>
</html>
