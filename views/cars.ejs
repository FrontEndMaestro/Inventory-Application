<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cars</title>
    <style>
      body {
        font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
        line-height: 1.5;
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
        background-color: #ffed48;
      }

      body > h1 {
        font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
        font-weight: 500;
        background-color: #ffffff;
        padding: 20px 30px;
        width: fit-content;
        border-radius: 30px;
        margin-left: 80px;
      }

      .car-list {
        list-style-type: none;
        padding-left: 0;
      }

      .car-card {
        border-radius: 110px;
        padding: 2rem 5rem;
        margin-bottom: 2rem;
        background-color: rgba(0, 0, 0, 0.3);
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }

      .car-heading {
        color: white;
        background-color: #010000;
        padding-left: 25px;
        width: fit-content;
        border-radius: 30px;
        margin-top: 0;
        display: flex;
        align-items: center;
      }

      .car-heading > span {
        background-color: #8200ff;
        padding: 15px 20px;
        border-radius: 30px;
        margin-left: 10px;
        color: white;
        font-weight: 500;
        font-size: 1rem;
      }

      .car-details {
        color: black;
        font-weight: 600;
        margin-left: 2rem;
        margin-bottom: 1rem;
        font-size: 1.1rem;
        border: 2px solid rgb(82, 82, 82);
        padding: 10px 20px;
        border-radius: 20px;
        box-shadow: 0px 5px 1px 0px rgb(0 0 255 / 0.2);
      }

      .action-buttons {
        margin-top: 1rem;
        margin-left: 2rem;
      }

      .btn {
        display: inline-block;
        margin-right: 15px;
        padding: 12px 30px;
        text-decoration: none;
        font-weight: 600;
        border-radius: 90px;
        border: 2px solid white;
        cursor: pointer;
        transition: all .5s ease;
        font-size: 1rem;
        font-family: inherit;
      }

      .btn-edit {
        background-color: rgba(178, 178, 178, 0.3);
        color: white;
      }

      .btn-delete {
        background-color: #ff3b3b;
        color: white;
      }

      .btn:hover {
        scale: 1.1;
        background-color: #ffffff;
        color: #000;
      }

      .add{
        font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
        display: inline-block;
        outline: none;
        border: none;
        padding: 5px 20px;
        border-radius: 30px;
        display: flex;
        align-items: center ;
        justify-content: center;
        transition: all 0.2s ease;
        font-size: 2rem;
        text-decoration: none;
        background-color: white;
        width: fit-content;
        right:20%;
        top: 8%;
        position: absolute;
        color: black;
      }
      .add:hover{
        scale: 1.1;
        cursor: pointer;
        background-color: #8200ff;
        color: white;

      }

      @media(width<=640px){
        body{
          display: flex;
          flex-direction: column;
          align-items: center;
        }
        body>h1{
          margin: 0;
          margin-bottom: 10px;
        }
        .add{
          position: relative;
          top: auto;
          right: auto;
          
        }

        .car-card{
          display: flex;
          flex-direction: column;
          align-items: center;
        }
        .car-details{
          margin-left: 0;
        }

        .action-buttons{
          margin-left: 0;
        }

      }

      @media (width<=440px){
        .action-buttons{
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .car-card{
          padding: 1rem 3rem;
        }

        .car-list{
          display: flex;
          flex-direction: column;
          align-items: center;
        }

        .action-buttons>.btn{
          margin: 0;
        }

        .action-buttons{
          gap: 5px;
          display: flex;
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <h1>Manage Cars</h1>
   <a href="/cars/create" class="add">Add</a>

    <ul class="car-list">
      <% cars.forEach(car => { %>
        <li class="car-card">
          
          <h3 class="car-heading">
            <%= car.name %> 
            <span>
              <%= car.company_name %>
            </span>
          </h3>
          
          <div class="car-details">
            Year: <%= car.model_year %> | Trim: <%= car.trim %> | Price: $<%= car.price %>
          </div>

          <div class="action-buttons">
            <a href="/cars/update/<%=car.id%>" class="btn btn-edit">Edit</a>
            <button onclick="deleteCar('<%=car.id%>')" class="btn btn-delete">Delete</button>
          </div>

        </li>
      <% }) %>
    </ul>

  </body>
  <script>

addEventListener("pageshow",(event)=>{
      if(event.persisted){
        window.location.reload();
      }
    })


    async function deleteCar(carId) {
      if (!confirm("Are you sure you want to delete this car?")) return;
      
      try {
        const response = await fetch(`/cars/delete/${carId}`, {
          method: "DELETE"
        });
        
        if (response.ok) {
          window.location.reload();
        } else {
          console.error("Cant delete car", response.status);
        }
      } catch (error) {
        console.error(error);
      }
    }
  </script>
</html>