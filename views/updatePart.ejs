<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update Part</title>
    <style>
      body {
        font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;
        line-height: 1.5;
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
        background-color: #ffed48;
      }

      h1 {
        font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
        font-weight: 500;
        background-color: #ffffff;
        padding: 20px 30px;
        width: fit-content;
        border-radius: 30px;
        margin-bottom: 2rem;
      }

      .form-container {
        border-radius: 80px;
        padding: 3rem 5rem;
        background-color: rgba(0, 0, 0, 0.3);
        color: white;
      }

      form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      label {
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: -1rem;
      }

      input[type="text"],
      input[type="number"] {
        padding: 15px 20px;
        border-radius: 30px;
        border: none;
        font-family: inherit;
        font-size: 1rem;
        background-color: #ffffff;
        width: 100%;
        box-sizing: border-box;
      }

      input:focus, .select-wrapper:focus-within {
        outline: 3px solid #8200ff;
      }

      .select-wrapper {
        background-color: #ffffff;
        border-radius: 30px;
        padding: 5px 20px; 
        box-sizing: border-box;
        width: 100%;
      }

      .select-wrapper select {
        width: 100%;
        padding: 10px 0;
        border: none;
        background: transparent;
        font-family: inherit;
        font-size: 1rem;
        color: #000;
        cursor: pointer;
      }

      .select-wrapper select:focus {
        outline: none; 
      }

      .btn-submit {
        margin-top: 1rem;
        padding: 15px 40px;
        font-weight: 600;
        border-radius: 90px;
        border: 2px solid white;
        cursor: pointer;
        transition: all .5s ease;
        font-size: 1.1rem;
        font-family: inherit;
        background-color: #8200ff;
        color: white;
        width: fit-content;
        align-self: flex-start;
      }

      .btn-submit:hover {
        scale: 1.1;
        background-color: #ffffff;
        color: #000;
      }
    </style>
  </head>
  <body>
    <h1>Update Part</h1>

    <div class="form-container">
      <form action="/parts/update/<%=part.part_id%>" method="POST">
        <label for="name">Part Name:</label>
        <input type="text" id="name" name="name" value="<%=part.name%>" required />

        <label for="car">For Car:</label>
        <div class="select-wrapper">
          <select name="carId" id="car" required>
            <option value="<%=part.car_id%>" selected><%=part.car_name%></option>
            <% cars.forEach(car=>{ %>
                <% if(car.name!=part.car_name) {%>
                <option value="<%= car.id %>"><%= car.name %></option><%}%>
            <% }) %>
          </select>
        </div>

        <label for="price">Price:</label>
        <input
          type="number"
          min="0.1"
          step="0.01"
          id="price"
          name="price"
          value="<%=part.price%>"
          required
        />
        
        <button type="submit" class="btn-submit">Update</button>
      </form>
    </div>
  </body>
</html>